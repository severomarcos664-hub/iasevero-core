from app.db.memory_store import save_message, get_recent_messages
import logging
from fastapi import APIRouter, Depends, Header, HTTPException

from app.config import settings
from app.dependencies import get_openai_service, get_telegram_service
from app.memory.chat_memory import add_message, get_messages
from app.models import TelegramWebhookMessage
from app.services.openai_service import OpenAIService
from app.services.telegram_service import TelegramService
from app.services.router_service import RouterService
from app.agents.agent_factory import invoke_agent
from app.tools.time_tool import get_brazil_time, get_current_time

logger = logging.getLogger("iasevero.telegram")
router = APIRouter(prefix="/telegram", tags=["telegram"])


@router.post("/webhook")
async def telegram_webhook(
    payload: TelegramWebhookMessage,
    x_telegram_bot_api_secret_token: str | None = Header(default=None),
    telegram_service: TelegramService | None = Depends(get_telegram_service),
    openai_service: OpenAIService | None = Depends(get_openai_service),
):
    expected = settings.telegram_webhook_secret
    if expected and x_telegram_bot_api_secret_token != expected:
        raise HTTPException(status_code=403, detail="Webhook secret inválido.")

    data = payload.model_dump()
    message = data.get("message") or {}

    if not message:
        return {"status": "ignored", "reason": "no_message"}

    text = (message.get("text") or "").strip()
    chat = message.get("chat") or {}
    chat_id = chat.get("id")

    if not chat_id:
        return {"status": "ignored", "reason": "no_chat_id"}

    if not telegram_service:
        raise HTTPException(status_code=503, detail="Telegram não configurado.")

    if text:
        add_message(chat_id, "user", text)

    text_low = text.lower()

    if text_low == "/start":
        reply = (
            "Olá! Eu sou a IASevero.\n\n"
            "Comandos disponíveis:\n"
            "/start\n/hora\n/status\n/version\n\n"
            "Você também pode conversar normalmente comigo."
        )

    elif text_low == "/hora" or any(k in text_low for k in [
        "que horas", "horas são", "hora atual", "hora em brasilia",
        "hora agora", "me diga a hora", "qual a hora"
    ]):
        reply = f"Agora é {get_brazil_time()}."

    elif any(k in text_low for k in [
        "que dia é hoje", "que dia e hoje", "qual a data", "data de hoje",
        "que dia do mês é hoje", "que dia do mes e hoje", "dia de hoje",
        "data atual", "me diga a data", "qual é a data", "qual e a data",
        "hoje que dia é", "hoje que dia e", "que dia do mês e hoje"
    ]):
        current = get_current_time("America/Sao_Paulo")
        reply = f"Hoje é {current['date']} ({current['timezone']})."

    elif any(k in text_low for k in [
        "data e hora", "data e hora agora", "me diga a data e hora"
    ]):
        current = get_current_time("America/Sao_Paulo")
        reply = f"Agora é {current['date']} {current['time']} ({current['timezone']})."

    elif text_low == "/status":
        reply = "IASevero online e operacional."

    elif text_low == "/version":
        reply = "IASevero Core v4.0.0"

    elif not text:
        reply = "Mensagem recebida."

    else:
        if openai_service:
            try:
                history = get_messages(chat_id)
                context = "\n".join(
                    [f"{m['role']}: {m['content']}" for m in history[-6:]]
                )
                prompt = (
                    f"Contexto recente:\n{context}\n\nUsuário: {text}"
                    if context else text
                )
                agent_name = router_service.route(text)
            reply = await invoke_agent(agent_name, text)
            except Exception as exc:
                logger.exception("Falha ao gerar resposta OpenAI: %r", exc)
                reply = f"Recebi sua mensagem: {text}"
        else:
            reply = f"Recebi sua mensagem: {text}"

    try:
        await telegram_service.send_message(chat_id=chat_id, text=reply)
        add_message(chat_id, "assistant", reply)
    except Exception as exc:
        logger.exception("Falha ao responder Telegram: %r", exc)
        raise HTTPException(status_code=502, detail="Falha ao enviar resposta ao Telegram.")

    return {"status": "ok"}


router_service = RouterService()
